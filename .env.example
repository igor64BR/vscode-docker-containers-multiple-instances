# URL SSH do repositório privado (use formato git@host:org/repo.git)
REPO_URL=git@github.com:seu-usuario/seu-repo.git

# Branch que cada instância vai checar/clonar (uma branch por instância → trabalho paralelo)
BRANCH_1=main
BRANCH_2=develop
BRANCH_3=feature/minha-branch

# Senha do code-server (mesma para todas as instâncias)
PASSWORD=troqueessasenha

# Porta do host mapeada para a porta 4200 (Angular/Nx dev server) de cada instância.
# Defaults: 4100, 4101, 4102 — permitem rodar as 3 instâncias em paralelo sem conflito.
APP_PORT_1=4100
APP_PORT_2=4101
APP_PORT_3=4102

# Identidade do git dentro dos containers
GIT_USER_NAME=Seu Nome
GIT_USER_EMAIL=voce@email.com
